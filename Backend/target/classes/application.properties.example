spring.application.name=vserv-backend
spring.config.import=optional:file:.env[.properties]

# Database
spring.datasource.url=${SPRING_DATASOURCE_URL}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.jpa.properties.hibernate.format_sql=true

# Server
server.port=${SERVER_PORT:8080}

# JWT
jwt.secret=${JWT_SECRET}
jwt.access-token-expiration-ms=3600000
jwt.refresh-token-expiration-ms=604800000

# Jackson
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.default-property-inclusion=non_null

# CORS
vserv.cors.allowed-origins=${VSERV_CORS_ALLOWED_ORIGINS}

# Email
resend.api.key=${RESEND_API_KEY}
resend.api.base-url=${RESEND_API_BASE_URL:https://api.resend.com}
resend.sender.email=${RESEND_SENDER_EMAIL:onboarding@resend.dev}
resend.sender.name=${RESEND_SENDER_NAME:Vserv}

razorpay.enabled=${RAZORPAY_ENABLED:false}
razorpay.key-id=${RAZORPAY_KEY_ID:}
razorpay.key-secret=${RAZORPAY_KEY_SECRET:}
razorpay.currency=${RAZORPAY_CURRENCY:INR}
razorpay.company-name=${RAZORPAY_COMPANY_NAME:VServ}

twilio.enabled=${TWILIO_ENABLED:false}
twilio.account-sid=${TWILIO_ACCOUNT_SID:}
twilio.auth-token=${TWILIO_AUTH_TOKEN:}
twilio.phone-number=${TWILIO_PHONE_NUMBER:}

# Required environment variables
# JWT_SECRET=replace-with-a-strong-random-secret
# RESEND_API_KEY=your_resend_api_key
# RAZORPAY_ENABLED=true
# RAZORPAY_KEY_ID=rzp_test_xxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# TWILIO_ENABLED=true
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+19783003761
